# Public site URL for metadata / OG (optional on Vercel — VERCEL_URL is used if unset)
NEXT_PUBLIC_SITE_URL=https://the-king-hippopotamus.vercel.app

# GitHub API (server-only) — raises rate limits for BFF routes
GITHUB_TOKEN=

# Per-project backend base URLs (optional) — proxied by /api/projects/[slug]
PROJECT_API_HIPPO_EQUITY_RESEARCH=
PROJECT_API_FORENSIC_ANALYSIS=
PROJECT_API_SEMANTIC_WATCHDOG_AGENTS=
PROJECT_API_PDF2MARKDOWN=

# Iframe embeds for projects with embed strategy "iframe" (optional)
# Pattern: NEXT_PUBLIC_EMBED_<SLUG_UPPER_WITH_UNDERSCORES>
# Example for slug "supply-chain":
NEXT_PUBLIC_EMBED_SUPPLY_CHAIN=
